#!/usr/bin/env zsh
# AIエージェント(claude/codex)の状態をpane単位で記録し,tmuxのwindowタブ色(@ai_state)に反映する
# tmux外で動くエージェントはsession_id単位(sid-*.state)で記録する(ai-agent-listの一覧用)
#
# 使い方:
#   ai-agent-state <agent> <event>            # claude/codexのhooksから呼ぶ(stdin: hook JSON)
#   ai-agent-state --focus-reset [window_id]  # tmuxのフックから呼ぶ(doneをidleへ戻す)
#
# イベントと状態の対応:
#   UserPromptSubmit / PreToolUse / PostToolUse -> working
#   PermissionRequest             -> blocked
#   Notification                  -> blocked (権限以外の入力待ち,matcherで対象を限定して登録する)
#   Stop                          -> done (background_tasks実行中はworking維持)
#   SessionStart                  -> idle
#   SessionEnd                    -> 状態クリア
set -eu

if [[ -z ${AI_AGENTS_CONFIG_DIR_PATH:-} ]]; then
  print "$0: AI_AGENTS_CONFIG_DIR_PATH is not set"
  exit 1
fi

state_dir=$AI_AGENTS_CONFIG_DIR_PATH/state

# イベントから状態を決定する(Stopはstdin JSONのbackground_tasksを考慮)
__resolve_state() {
  local event input
  event=$1
  input=$2

  case $event in
    UserPromptSubmit | PreToolUse | PostToolUse)
      print working
      ;;
    PermissionRequest)
      print blocked
      ;;
    Notification)
      # 入力待ち通知はターン中(working)のみblockedにする
      # (ターン終了後にも入力待ち系の通知が発火しStop後のidle/doneを上書きしてしまうため)
      if [[ -f $state_dir/$TMUX_PANE.state && $(cut -d' ' -f1 "$state_dir/$TMUX_PANE.state") == working ]]; then
        print blocked
      fi
      ;;
    SessionStart)
      print idle
      ;;
    Stop)
      # ターン終了時にバックグラウンドタスクが動いていればまだ作業中扱い
      # 完了したwindowをユーザーが見ている(attached+カレント)なら確認済みとしてidle扱い
      if print -r -- "$input" | jq -e '[.background_tasks[]? | select(.status == "running")] | length > 0' >/dev/null 2>&1; then
        print working
      elif [[ $(tmux display-message -p -t "$TMUX_PANE" '#{?#{&&:#{window_active},#{session_attached}},1,0}' 2>/dev/null) == 1 ]]; then
        print idle
      else
        print done
      fi
      ;;
  esac
}

# 状態ファイルへatomicに書き込む(内容: "<state> <agent>")
__write_state() {
  local pane_id state agent tmp_file
  pane_id=$1
  state=$2
  agent=$3

  tmp_file=$(mktemp "$state_dir/.state.XXXXXX")
  print -r -- "$state $agent" > "$tmp_file"
  mv -f "$tmp_file" "$state_dir/$pane_id.state"
}

# window内の全pane状態を集約する(優先度: blocked > done > working > idle)
__aggregate_window_state() {
  local target states state
  target=$1

  states=$(
    for pane_id in $(tmux list-panes -t "$target" -F '#{pane_id}' 2>/dev/null); do
      [[ -f $state_dir/$pane_id.state ]] || continue
      cut -d' ' -f1 "$state_dir/$pane_id.state"
    done
  )

  for state in blocked done working; do
    if [[ $states == *$state* ]]; then
      print $state
      return 0
    fi
  done

  print idle
}

# 集約した状態を対象windowの@ai_stateへ反映する
__apply_window_state() {
  local target
  target=$1

  tmux set-option -w -t "$target" @ai_state "$(__aggregate_window_state "$target")" 2>/dev/null || return 0
  tmux refresh-client -S >/dev/null 2>&1 || true
}

# tmux外エージェント用: イベントから状態を決定する(タブ反映が無いため可視判定なし)
__resolve_state_outside() {
  local event input state_file
  event=$1
  input=$2
  state_file=$3

  case $event in
    UserPromptSubmit | PreToolUse | PostToolUse)
      print working
      ;;
    PermissionRequest)
      print blocked
      ;;
    SessionStart)
      print idle
      ;;
    Notification)
      # 入力待ち通知はターン中(working)のみblockedにする
      if [[ -f $state_file && $(cut -f1 "$state_file") == working ]]; then
        print blocked
      fi
      ;;
    Stop)
      if print -r -- "$input" | jq -e '[.background_tasks[]? | select(.status == "running")] | length > 0' >/dev/null 2>&1; then
        print working
      else
        print done
      fi
      ;;
  esac
}

# tmux外エージェントの状態をatomicに書き込む(タブ区切り: state agent pid tty cwd)
__write_state_outside() {
  local key state agent agent_pid agent_tty cwd tmp_file
  key=$1
  state=$2
  agent=$3
  agent_pid=$4
  agent_tty=$5
  cwd=$6

  tmp_file=$(mktemp "$state_dir/.state.XXXXXX")
  printf '%s\t%s\t%s\t%s\t%s\n' "$state" "$agent" "$agent_pid" "$agent_tty" "$cwd" > "$tmp_file"
  mv -f "$tmp_file" "$state_dir/$key.state"
}

# フォーカスしたwindowのdoneをidleへ戻す(確認済み扱い,blockedは保持)
__focus_reset() {
  local window_id pane_id state agent
  window_id=$1

  for pane_id in $(tmux list-panes -t "$window_id" -F '#{pane_id}' 2>/dev/null); do
    [[ -f $state_dir/$pane_id.state ]] || continue
    read -r state agent < "$state_dir/$pane_id.state" || continue
    if [[ $state == done ]]; then
      __write_state "$pane_id" idle "$agent"
    fi
  done

  __apply_window_state "$window_id"
}

mkdir -p "$state_dir"

if [[ ${1:-} == --focus-reset ]]; then
  __focus_reset "${2:-$(tmux display-message -p '#{window_id}')}"
  exit 0
fi

if (( $# != 2 )); then
  print "$0: usage: ai-agent-state <agent> <event> | ai-agent-state --focus-reset [window_id]" 1>&2
  exit 1
fi

# tmux paneの外で動くエージェントはsession_id単位で記録する(tmuxタブ反映なし)
if [[ -z ${TMUX_PANE:-} ]]; then
  input=$(cat 2>/dev/null || true)
  session_id=$(print -r -- "$input" | jq -r '.session_id // empty' 2>/dev/null || true)
  [[ -n $session_id ]] || exit 0

  state_file=$state_dir/sid-$session_id.state

  if [[ $2 == SessionEnd ]]; then
    rm -f "$state_file" "$state_dir/sid-$session_id.meta.json"
    exit 0
  fi

  state=$(__resolve_state_outside "$2" "$input" "$state_file")
  [[ -n $state ]] || exit 0

  if [[ -f $state_file && $(cut -f1 "$state_file") == $state ]]; then
    exit 0
  fi

  # エージェント本体のPID(hookはエージェントからシェル経由で起動されるため親の親)と
  # TTY・作業ディレクトリを記録する(一覧での生存判定・表示用)
  agent_pid=$(ps -o ppid= -p $PPID 2>/dev/null | tr -d ' ')
  agent_tty=$(ps -o tty= -p "${agent_pid:-0}" 2>/dev/null | tr -d ' ')
  cwd=$(print -r -- "$input" | jq -r '.cwd // empty' 2>/dev/null || true)
  __write_state_outside "sid-$session_id" "$state" "$1" "${agent_pid:-}" "${agent_tty:-}" "${cwd:-}"
  exit 0
fi

input=$(cat 2>/dev/null || true)

if [[ $2 == SessionEnd ]]; then
  rm -f "$state_dir/$TMUX_PANE.state" "$state_dir/$TMUX_PANE.meta.json"
  __apply_window_state "$TMUX_PANE"
  exit 0
fi

state=$(__resolve_state "$2" "$input")

# 未知のイベントは無視する
[[ -n $state ]] || exit 0

# 状態が変わらないならtmux反映を省く(PreToolUseの高頻度発火対策)
if [[ -f $state_dir/$TMUX_PANE.state && $(cut -d' ' -f1 "$state_dir/$TMUX_PANE.state") == $state ]]; then
  exit 0
fi

__write_state "$TMUX_PANE" "$state" "$1"
__apply_window_state "$TMUX_PANE"
