#!/usr/bin/env zsh
# AIエージェント(claude/codex)の状態一覧をwatch表示する(tmux内外を統合)
#
# 使い方:
#   ai-agents-list           # 自動更新表示(1秒間隔, qで終了)
#   ai-agents-list --once    # 1回だけ出力して終了
#
# 表示対象:
#   tmux内のエージェント: <pane_id>.state (TARGET=セッション:window.pane)
#   tmux外のエージェント: sid-<session_id>.state (TARGET=tty)
set -eu

zmodload zsh/datetime

state_dir=${AI_AGENT_STATE_DIR_PATH:-$HOME/.config/ai_agents/state}

# 一覧の並び順(上ほど対応が必要): blocked > done > working > idle
__priority_for() {
  case $1 in
    blocked) print 0 ;;
    done)    print 1 ;;
    working) print 2 ;;
    *)       print 3 ;;
  esac
}

# 状態ラベル(ANSI色付き・パディング込みで幅を揃える)
__label_for() {
  case $1 in
    blocked) print '\e[1;33m● Input  \e[0m' ;;
    done)    print '\e[1;31m● Done   \e[0m' ;;
    working) print '\e[32m● Working\e[0m' ;;
    *)       print '\e[90m● Idle   \e[0m' ;;
  esac
}

# トークン数を 61K / 1M 形式に
__fmt_tokens() {
  local t
  t=${1:-0}
  if   (( t >= 1000000 )); then printf '%dM' $(( t / 1000000 ))
  elif (( t >= 1000 ));    then printf '%dK' $(( t / 1000 ))
  else                          printf '%d' $t
  fi
}

# 最終更新からの経過時間を 8s / 15m / 2h 形式に
__fmt_last() {
  local rem
  # NOTE: (( rem = ... )) は結果0でexit 1となりset -eで死ぬため算術展開で代入する
  rem=$(( EPOCHSECONDS - $1 ))
  (( rem < 0 )) && rem=0
  if   (( rem < 60 ));   then print "${rem}s"
  elif (( rem < 3600 )); then print "$(( rem / 60 ))m"
  else                        print "$(( rem / 3600 ))h"
  fi
}

# 現存しないpane・死んだプロセスの状態ファイルを掃除する
__cleanup_stale() {
  local live state_file id pid
  live=$(tmux list-panes -a -F '#{pane_id}' 2>/dev/null || true)

  for state_file in "$state_dir"/%*.state(N); do
    id=${${state_file:t}%.state}
    if [[ $'\n'$live$'\n' != *$'\n'$id$'\n'* ]]; then
      rm -f "$state_file" "$state_dir/$id.meta.json"
    fi
  done

  for state_file in "$state_dir"/sid-*.state(N); do
    pid=$(cut -f3 "$state_file" 2>/dev/null || true)
    if [[ -z ${pid:-} ]] || ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$state_file" "${state_file%.state}.meta.json"
    fi
  done
}

# メタ情報の表示列を出力する(形式: "<model>\t<context>")
__meta_columns() {
  local meta_file model cx_pct cx_tok
  meta_file=$state_dir/$1.meta.json

  if [[ -f $meta_file ]]; then
    model=$(jq -r '.model // "-"' "$meta_file" 2>/dev/null || print -- -)
    cx_pct=$(jq -r '.cx_pct // 0 | floor' "$meta_file" 2>/dev/null || print 0)
    cx_tok=$(jq -r '.cx_tok // 0' "$meta_file" 2>/dev/null || print 0)
    printf '%s\t%s' "$model" "${cx_pct}% $(__fmt_tokens "$cx_tok")"
  else
    printf -- '-\t-'
  fi
}

# 1行分の表示を整形する(形式: "<priority>\t<整形済み表示行>")
__format_row() {
  local target agent state dir key mtime meta model ctx
  target=$1
  agent=$2
  state=$3
  dir=$4
  key=$5
  mtime=$6

  meta=$(__meta_columns "$key")
  model=${meta%$'\t'*}
  ctx=${meta#*$'\t'}

  printf '%s\t%-18s %-7s %s %-22s %-12s %-9s %s\n' \
    "$(__priority_for "$state")" \
    "${target[1,18]}" \
    "${agent[1,7]}" \
    "$(__label_for "$state")" \
    "${dir[1,22]}" \
    "${model[1,12]}" \
    "$ctx" \
    "$(__fmt_last "$mtime")"
}

# 全エージェントのデータ行を出力する
__emit_rows() {
  local line pane_id session win pane pane_path state agent
  local state_file key agent_pid agent_tty cwd mtime sep
  local -a parts

  __cleanup_stale

  # tmux内(pane単位)
  sep=$'\t'
  tmux list-panes -a -F "#{pane_id}${sep}#{session_name}${sep}#{window_index}${sep}#{pane_index}${sep}#{pane_current_path}" 2>/dev/null \
    | while IFS= read -r line; do
        parts=("${(@ps.\t.)line}")
        pane_id=${parts[1]:-}
        session=${parts[2]:-}
        win=${parts[3]:-}
        pane=${parts[4]:-}
        pane_path=${parts[5]:-}
        [[ -n $pane_id && -f $state_dir/$pane_id.state ]] || continue
        read -r state agent < "$state_dir/$pane_id.state" || continue
        mtime=$(stat -f %m "$state_dir/$pane_id.state" 2>/dev/null || print $EPOCHSECONDS)

        __format_row "${session}:${win}.${pane}" "$agent" "$state" "${pane_path:t}" "$pane_id" "$mtime"
      done

  # tmux外(session_id単位)
  for state_file in "$state_dir"/sid-*.state(N); do
    key=${${state_file:t}%.state}
    IFS=$'\t' read -r state agent agent_pid agent_tty cwd < "$state_file" || continue
    mtime=$(stat -f %m "$state_file" 2>/dev/null || print $EPOCHSECONDS)

    __format_row "${agent_tty:-pid:$agent_pid}" "$agent" "$state" "${cwd:t}" "$key" "$mtime"
  done
}

# ヘッダ+ソート済み一覧を出力する
__render() {
  printf 'AI Agents  %s  (q: quit)\n' "$(strftime '%H:%M:%S' $EPOCHSECONDS)"
  printf '%-18s %-7s %-9s %-22s %-12s %-9s %s\n' TARGET AGENT STATUS DIR MODEL CONTEXT LAST
  __emit_rows | sort -t$'\t' -k1,1n | cut -f2-
}

if [[ ${1:-} == --once ]]; then
  __render
  exit 0
fi

# watch表示(1秒間隔で再描画, qで終了)
trap 'printf "\e[?25h"' EXIT
trap 'exit 0' INT TERM
printf '\e[?25l'

while :; do
  out=$(__render)
  printf '\e[H\e[J%s\n' "$out"

  if [[ -t 0 ]]; then
    if read -t 1 -k 1 key 2>/dev/null && [[ $key == q ]]; then
      break
    fi
  else
    sleep 1
  fi
done
