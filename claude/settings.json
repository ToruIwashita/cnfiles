{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "TMP_LATEST_AI_PRECOMPACT_SNAPSHOT_FILE_PATH": "~/works/tmp/latest-ai-precompact-snapshot.md"
  },
  "permissions": {
    "allow": [
      "Bash(zsh:*)",
      "Bash(tmux:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(ps:*)",
      "Bash(top:*)",
      "Bash(vm_stat:*)",
      "Bash(source:*)",
      "Bash(pbcopy:*)",
      "Bash(gh pr:*)",
      "Bash(gis:*)",
      "Bash(gpr:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git pull:*)",
      "Bash(git reset:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git symbolic-ref:*)",
      "Read(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "Task(*)",
      "TodoRead(*)",
      "TodoWrite(*)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__codex__codex",
      "mcp__codex__codex-reply"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(gh pr merge:*)",
      "Bash(git -C:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git rm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.aws/**)",
      "Write(.env*)",
      "Write(**/secrets/**)"
    ],
    "additionalDirectories": [
      "~/markdown_texts/",
      "~/works/memolist/",
      "~/works/git_worktrees/"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "tmux *",
      "bundle *",
      "gis *",
      "gpr *",
      "gh *",
      "git fetch*",
      "git pull*",
      "git status*"
    ],
    "network": {
      "allowedDomains": [
        "slack.com",
        "github.com"
      ]
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay /System/Library/Sounds/Funk.aiff || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay /System/Library/Sounds/Funk.aiff || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${TMP_LATEST_AI_PRECOMPACT_SNAPSHOT_FILE_PATH/#\\~/$HOME}\"; test -s \"$f\" && cat \"$f\"; true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd'); model=$(echo \"$input\" | jq -r '.model.display_name'); dir_name=$(basename \"$current_dir\"); cd \"$current_dir\" 2>/dev/null; if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo 'detached'); printf \"\\033[1;33m(%s)\\033[0m [git|* \\033[32m%s\\033[0m]@%s\" \"$model\" \"$branch\" \"$dir_name\"; else printf \"\\033[1;33m(%s)\\033[0m []@%s\" \"$model\" \"$dir_name\"; fi"
  },
  "enabledPlugins": {
    "sentry-mcp@sentry-mcp": true
  },
  "extraKnownMarketplaces": {
    "sentry-mcp": {
      "source": {
        "source": "github",
        "repo": "getsentry/sentry-mcp"
      }
    }
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "codex": {
      "command": "codex",
      "args": [
        "mcp-server"
      ],
      "env": {}
    }
  }
}
