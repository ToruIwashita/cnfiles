{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "SYSTEM_SOUNDS_DIR_PATH": "/System/Library/Sounds"
  },
  "permissions": {
    "allow": [
      "Bash(zsh:*)",
      "Bash(tmux:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(ps:*)",
      "Bash(top:*)",
      "Bash(vm_stat:*)",
      "Bash(source:*)",
      "Bash(pbcopy:*)",
      "Bash(gh pr:*)",
      "Bash(gis:*)",
      "Bash(gpr:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git pull:*)",
      "Bash(git reset:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git symbolic-ref:*)",
      "Edit(*)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "mcp__codex__codex",
      "mcp__codex__codex-reply"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(gh pr merge:*)",
      "Bash(git -C:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git rm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(socat:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(rsync:*)",
      "Bash(ftp:*)",
      "Bash(telnet:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",
      "Bash(security:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_dsa)",
      "Read(id_ecdsa)",
      "Read(id_ecdsa_sk)",
      "Read(id_ed25519)",
      "Read(id_ed25519_sk)",
      "Read(**/.ssh/**)",
      "Read(~/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.aws/**)",
      "Read(~/.aws/**)",
      "Read(~/.netrc)",
      "Read(**/secrets/**)",
      "Edit(.env*)",
      "Edit(**/secrets/**)"
    ],
    "ask": [
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.cnfiles/claude/settings.json)",
      "Edit(~/.claude/CLAUDE.md)",
      "Edit(~/.cnfiles/claude/CLAUDE.md)"
    ],
    "additionalDirectories": [
      "~/markdown_texts/",
      "~/works/memolist/",
      "~/works/git_worktrees/"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude PreToolUse"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '(.tool_input.file_path // \"\") as $f | ((env.TMP_DIR_PATH // \"\") + \"/\") as $d | ((env.SYSTEM_TMP_AI_DIR_PATH // \"\") + \"/\") as $t | if $d != \"/\" and $t != \"/\" and ($f | startswith($d)) and $f != (env.TMP_LATEST_AI_PRECOMPACT_SNAPSHOT_FILE_PATH // \"\") then {hookSpecificOutput: {hookEventName: \"PreToolUse\", permissionDecision: \"allow\", permissionDecisionReason: \"$TMP_DIR_PATH への書き込みを $SYSTEM_TMP_AI_DIR_PATH へリダイレクト\", updatedInput: (.tool_input | .file_path = ($t + ($f | ltrimstr($d) | gsub(\"/\"; \"_\"))))}} else empty end'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude PostToolUse"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude PermissionRequest"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay \"$SYSTEM_SOUNDS_DIR_PATH/Funk.aiff\" || true"
          },
          {
            "type": "command",
            "command": "ai-agent-state claude Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null 2>&1 && afplay \"$SYSTEM_SOUNDS_DIR_PATH/Funk.aiff\" || true"
          }
        ]
      },
      {
        "matcher": "permission_prompt|agent_needs_input|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude Notification"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$TMP_LATEST_AI_PRECOMPACT_SNAPSHOT_FILE_PATH\"; test -s \"$f\" && cat \"$f\" && : > \"$f\"; true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude SessionStart"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-agent-state claude SessionEnd"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-code-statusline"
  },
  "enabledPlugins": {
    "sentry-mcp@sentry-mcp": true
  },
  "extraKnownMarketplaces": {
    "sentry-mcp": {
      "source": {
        "source": "github",
        "repo": "getsentry/sentry-mcp"
      }
    }
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "slack.com",
        "github.com",
        "rubygems.org",
        "index.rubygems.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.config/ai_agents/"
      ]
    },
    "credentials": {
      "envVars": [
        {
          "name": "GITHUB_TOKEN",
          "mode": "deny"
        }
      ]
    },
    "excludedCommands": [
      "tmux *",
      "bundle *",
      "gis *",
      "gpr *",
      "gh *",
      "git fetch*",
      "git pull*",
      "git status*",
      "pbcopy*"
    ]
  },
  "effortLevel": "xhigh",
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "codex": {
      "command": "codex",
      "args": [
        "mcp-server"
      ],
      "env": {}
    }
  }
}
